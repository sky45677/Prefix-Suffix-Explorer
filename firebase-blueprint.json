{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific profile information and preferences.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "quizPreferences": {
          "type": "object",
          "properties": {
            "defaultType": { "type": "string", "enum": ["mcq", "fill", "boolean"] },
            "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "expert"] }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "xp": { "type": "number" },
            "streak": { "type": "number" },
            "level": { "type": "number" }
          }
        }
      },
      "required": ["email"]
    },
    "LexiconEntry": {
      "title": "Lexicon Entry",
      "description": "A word saved by the user to their personal lexicon.",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "definition": { "type": "string" },
        "morphology": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "definition", "morphology", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/lexicon/{entryId}": {
      "schema": "LexiconEntry",
      "description": "Collection of words saved by the user."
    }
  }
}
